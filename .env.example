# Copy this file to .env or .env.local on each machine.
# Do not commit real secrets.

# Prisma (Supabase Postgres)
#
# In Supabase Dashboard:
#   Project Settings -> Database -> Connection string
# Use the *Connection pooling* URI for DATABASE_URL (runtime)
# Use the *Direct connection* URI for DIRECT_URL (migrations)
#
# Notes:
# - Keep the ?sslmode=require if Supabase provides it.
# - If your pooled URI includes pgbouncer, keep ?pgbouncer=true.
# - Do NOT commit your real secrets; copy this file to your local env setup.

DATABASE_URL="postgresql://USER:PASSWORD@HOST:6543/postgres?pgbouncer=true&sslmode=require"
DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/postgres?sslmode=require"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="replace-with-a-random-secret"

# Google OAuth (optional)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Supabase JS client (used for uploads / client-side access)
NEXT_PUBLIC_SUPABASE_URL="https://YOUR_PROJECT_REF.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="YOUR_SUPABASE_ANON_KEY"

# Optional (server-only). Only needed if you call Supabase from server with elevated perms.
SUPABASE_SERVICE_ROLE_KEY="" 

# Uploads
# The app uses a public Supabase Storage bucket named "uploads".
# If it does not exist, the server upload endpoint will create it using the service role key.
